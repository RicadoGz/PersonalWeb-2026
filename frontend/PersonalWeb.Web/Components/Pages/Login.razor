@page "/login"

<PageTitle>Login</PageTitle>

<div class="login-page-shell">
    <section class="login-page-copy">
        <p class="eyebrow">Workspace Access</p>
        <h1>Login for the admin workspace</h1>
        <p class="intro">
            Use the demo credentials to test the current auth flow. This page is separate from the
            public homepage so the portfolio stays clean while the login flow remains accessible.
        </p>

        <div class="contact-row">
            <a href="/">Back to home</a>
            <span>ASP.NET Core API</span>
            <span>Blazor login flow</span>
        </div>
    </section>

    <LoginFormCard UsernameId="page-login-username" PasswordId="page-login-password" />
</div>
