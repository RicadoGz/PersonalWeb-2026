@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-brand">
                <span class="brand-mark"></span>
                <span>Ricardo Gao</span>
            </div>
            <div class="top-row-actions">
                <LoginPanel />
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
@* body means different main page content *@
<FloatingAgentWidget @rendermode="InteractiveServer" />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
