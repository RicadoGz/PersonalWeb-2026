@inject IHttpClientFactory HttpClientFactory
@* inject to get a server-side component*@
<div class="floating-agent">
    @if (isOpen)
    {
        <section class="floating-agent-panel">
            <div class="floating-agent-head">
                <div>
                    <strong>Ricardo AI</strong>
                    <p>chatbot</p>
                    <small class="floating-agent-subline">Real-time RAG generated from portfolio context</small>
                </div>
                <button type="button" class="floating-close" @onclick="Toggle">×</button>
            </div>

            <div class="floating-agent-body">
                @foreach (var message in messages)
                {
                    <div class="agent-message @(message.IsUser ? "agent-message-user" : "agent-message-bot")">
                        @message.Text
                    </div>
                }
            </div>

            <div class="prompt-chip-row">
                @foreach (var prompt in quickPrompts)
                {
                    <button class="prompt-chip" type="button" @onclick='() => UsePrompt(prompt)'>@prompt</button>
                }
            </div>

            <form class="floating-agent-input" @onsubmit="HandleSubmit">
                <input
                    class="floating-agent-textbox"
                    type="text"
                    placeholder="Paste a job description or ask about fit"
                    @bind="draftMessage" />
                <button class="floating-send" type="submit" disabled="@isSending">@(isSending ? "..." : "Send")</button>
            </form>
        </section>
    }

    <button class="floating-agent-launcher" type="button" @onclick="Toggle" aria-label="Open Ricardo AI chat">
        <span class="floating-agent-launcher-icon">AI</span>
        <span class="floating-agent-launcher-copy">
            <strong>Ricardo AI</strong>
            <small>@LauncherHint</small>
        </span>
    </button>
</div>

@code {
    // UI fallback strings used when the backend does not return a useful answer.
    private const string EmptyAnswerMessage = "I could not generate an answer yet.";
    private const string RequestFailedMessage = "The portfolio assistant is currently unavailable. Please try again.";
    private const string RequestRejectedMessage = "The portfolio assistant could not answer right now.";

    // These are the three main entry prompts the backend currently understands well.
    private static readonly string[] quickPrompts =
    [
        "Summarize Ricardo for a recruiter",
        "Match Ricardo to this JD",
        "Which projects fit AI roles?"
    ];

    private static readonly List<ChatMessage> InitialMessages =
    [
        new(false, "I am AI assistant developer by Ricardo, Paste a job description and I will explain why Ricardo is a fit based on his projects, skills, and experience. (if he did not fit i won not lie on you:)"),

    ];

    // Local UI state for opening/closing the widget and handling send operations.
    private bool isOpen;
    private bool isSending;
    private string draftMessage = string.Empty;
    private readonly List<ChatMessage> messages = [.. InitialMessages];

    // The launcher hint changes depending on whether the widget is open.
    private string LauncherHint => isOpen ? "Click to close" : "Paste a JD and test fit";

    private void Toggle()
    {
        isOpen = !isOpen;
    }

    private void UsePrompt(string prompt)
    {
        draftMessage = prompt;
    }

    private async Task HandleSubmit()
    {
        // Trim early so we do not send blank or whitespace-only messages.
        var userMessage = draftMessage.Trim();
        if (string.IsNullOrWhiteSpace(userMessage) || isSending)
        {
            return;
        }

        // Optimistically add the user message before the backend round-trip finishes.
        AddUserMessage(userMessage);
        draftMessage = string.Empty;
        isSending = true;

        try
        {
            // The named HttpClient is configured in frontend Program.cs to point at the backend API.
            var client = HttpClientFactory.CreateClient("BackendApi");
            var response = await client.PostAsJsonAsync("/api/chat", new ChatRequest(userMessage));

            if (!response.IsSuccessStatusCode)
            {
                AddAssistantMessage(RequestRejectedMessage);
                return;
            }

            // The backend returns a normalized ChatResponse with Answer + Sources.
            // Right now the UI renders only the Answer text.
            var payload = await response.Content.ReadFromJsonAsync<ChatResponse>();
            AddAssistantMessage(payload?.Answer ?? EmptyAnswerMessage);
        }
        catch
        {
            // Network failures and backend failures collapse to one friendly UI message.
            AddAssistantMessage(RequestFailedMessage);
        }
        finally
        {
            isSending = false;
        }
    }

    private void AddUserMessage(string text)
    {
        messages.Add(new ChatMessage(true, text));
    }

    private void AddAssistantMessage(string text)
    {
        messages.Add(new ChatMessage(false, text));
    }

    // Local frontend-only records so the component can deserialize the API response.
    private sealed record ChatMessage(bool IsUser, string Text);

    private sealed record ChatRequest(string Message);

    private sealed record ChatResponse(string Answer, List<ChatSource>? Sources);

    private sealed record ChatSource(string Title, string Snippet, string Category);
}
