@implements IDisposable

@* take different index for the component *@
<div class="hello-rotator" aria-label="Hello in different languages">
    <div class="hello-rotator-window">
        <span class="hello-rotator-word">@greetings[currentIndex]</span>
    </div>
</div>

@code {
    private readonly string[] greetings =
    [
        "Hi",
        "你好",
        "Bonjour",
        "Hola",
        "こんにちは",
        "안녕하세요",
        "Ciao",
        "مرحبا",
        "Olá",
        "Merhaba",
        "नमस्ते"
    ];

    private int currentIndex;
    private Timer? timer;

    protected override void OnInitialized()
    {
        timer = new Timer(TimerCallback, null, 1200, 1200);
    }

    private void TimerCallback(object? state)
    {
        currentIndex = currentIndex + 1;

        if (currentIndex >= greetings.Length)
        {
            currentIndex = 0;
        }
    //render the component on the UI thread after updating the index
        InvokeAsync(UpdateUI);
    }

    private void UpdateUI()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}
